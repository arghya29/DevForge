{
  "extends": ["html-validate:recommended"],
  "rules": {
    "doctype-style": ["error", { "style": "lowercase" }],
    "void-style": "off",
    "no-inline-style": "off",
    "attr-quotes": ["error", { "style": "double" }],
    "no-trailing-whitespace": "warn",
    "element-permitted-content": "error",
    "missing-doctype": "error",
    "require-sri": "off",
    "script-type": "off",
    "long-title": "off"
  }
}
